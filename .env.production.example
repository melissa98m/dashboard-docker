# =============================================================================
# Production environment — Dashboard Docker (Raspberry Pi)
# Copier vers .env et remplir les valeurs sensibles avant déploiement.
# =============================================================================

# Ports exposés sur l'hôte (8000, 8080, 443 déjà utilisés → 8001/8002)
# Si reverse proxy dans ce stack: utiliser 8443 au lieu de 443 pour HTTPS
PORT_API=8001
PORT_WEB=8002

# API
APP_ENV=production
DATABASE_URL=sqlite:////data/dashboard.db
DOCKER_HOST=unix:///var/run/docker.sock

# CORS — origines autorisées (frontend)
CORS_ALLOW_ORIGINS=https://dashboard.melissa-mangione.com
CORS_ALLOW_METHODS=GET,POST,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,X-CSRF-Token,X-API-Key

# OBLIGATOIRE en prod — générer avec: openssl rand -hex 32
API_SECRET_KEY=

# Auth
AUTH_ENABLED=true
AUTH_SESSION_COOKIE_NAME=dashboard_session
AUTH_CSRF_COOKIE_NAME=dashboard_csrf
AUTH_SESSION_TTL_SECONDS=28800
AUTH_SESSION_EXTEND_THRESHOLD_SECONDS=900
# Prod: HTTPS uniquement
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_FAILED_LOGIN_LIMIT=5
AUTH_LOCKOUT_MINUTES=15
AUTH_SESSION_RETENTION_AUTO_ENABLED=true
AUTH_SESSION_RETENTION_POLL_SECONDS=3600

# Bootstrap admin — créé au premier démarrage si base vide
AUTH_BOOTSTRAP_ADMIN_USERNAME=
AUTH_BOOTSTRAP_ADMIN_PASSWORD=

# SSE / alertes / événements
SSE_MAX_CONNECTIONS=20
ALERT_ENGINE_ENABLED=true
ALERT_POLL_SECONDS=10
EVENT_WATCHER_ENABLED=true
EVENT_WATCHER_NTFY_TOPIC=
# URL publique de l'API (pour liens restart dans les notifications)
PUBLIC_API_URL=https://api.melissa-mangione.com
RESTART_ACTION_TTL_SECONDS=300
RESTART_TOKEN_RATE_LIMIT_WINDOW_SECONDS=60
RESTART_TOKEN_RATE_LIMIT_MAX_ATTEMPTS=20
EXECUTION_STREAM_TOKEN_TTL_SECONDS=120
COMMAND_DISCOVERY_CACHE_TTL_SECONDS=300

# Logs / audit
LOG_SNAPSHOT_REDACTION_ENABLED=true
LOG_SNAPSHOT_REDACTION_EXTRA_PATTERNS=
AUDIT_RETENTION_DAYS=90
AUDIT_RETENTION_AUTO_ENABLED=true
AUDIT_RETENTION_POLL_SECONDS=86400

# Frontend — URL de l'API exposée au navigateur
NEXT_PUBLIC_API_URL=https://api.melissa-mangione.com

# Notifications (optionnel)
NTFY_BASE_URL=
NTFY_TOPIC=
RESEND_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# act (GitHub Actions local) — optionnel
ACT_ENABLED=false
ACT_WORKFLOWS_PATH=/workspace
