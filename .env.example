# Ports exposés (override en prod si 8000/3000 déjà utilisés)
# PORT_API=8001
# PORT_WEB=8002

# API
APP_ENV=development
DATABASE_URL=sqlite:////data/dashboard.db
DOCKER_HOST=unix:///var/run/docker.sock
# Allowed browser origins for CORS (comma-separated, no trailing slash)
CORS_ALLOW_ORIGINS=http://localhost:3000
# Allowed HTTP methods for CORS preflight (comma-separated)
CORS_ALLOW_METHODS=GET,POST,PATCH,DELETE,OPTIONS
# Allowed custom headers for CORS preflight (comma-separated)
CORS_ALLOW_HEADERS=Content-Type,X-CSRF-Token,X-API-Key
API_SECRET_KEY=
# Auth session (session cookies + CSRF). Recommandé ON.
AUTH_ENABLED=true
AUTH_SESSION_COOKIE_NAME=dashboard_session
AUTH_CSRF_COOKIE_NAME=dashboard_csrf
AUTH_SESSION_TTL_SECONDS=28800
AUTH_SESSION_EXTEND_THRESHOLD_SECONDS=900
# false = cookies envoyés en HTTP (dev local). true = HTTPS uniquement (prod).
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_FAILED_LOGIN_LIMIT=5
AUTH_LOCKOUT_MINUTES=15
AUTH_MFA_ISSUER=Dashboard
AUTH_MFA_TOTP_WINDOW_STEPS=1
AUTH_MFA_CHALLENGE_TTL_SECONDS=300
AUTH_MFA_CHALLENGE_MAX_ATTEMPTS=5
AUTH_MFA_ENROLLMENT_TTL_SECONDS=600
AUTH_SESSION_RETENTION_AUTO_ENABLED=true
AUTH_SESSION_RETENTION_POLL_SECONDS=3600
# Optional bootstrap admin on first run (recommended to set in deployment env)
AUTH_BOOTSTRAP_ADMIN_USERNAME=
AUTH_BOOTSTRAP_ADMIN_PASSWORD=
# Max concurrent SSE streams accepted by API
SSE_MAX_CONNECTIONS=20
# Auto-evaluate alert rules from Docker stats (default rules: CPU 90%, RAM 90% per container)
ALERT_ENGINE_ENABLED=true
ALERT_POLL_SECONDS=10
# Docker events watcher: notify on container die/oom
EVENT_WATCHER_ENABLED=true
# Optional ntfy topic override for downtime notifications (defaults to NTFY_TOPIC)
EVENT_WATCHER_NTFY_TOPIC=
# Public API URL used to build restart action links in notifications
PUBLIC_API_URL=http://localhost:8000
# Restart action token TTL (seconds)
RESTART_ACTION_TTL_SECONDS=300
# Rate limit for restart-by-token endpoint (anti-bruteforce)
RESTART_TOKEN_RATE_LIMIT_WINDOW_SECONDS=60
RESTART_TOKEN_RATE_LIMIT_MAX_ATTEMPTS=20
# Execution output stream token TTL (seconds)
EXECUTION_STREAM_TOKEN_TTL_SECONDS=120
# Command discovery cache TTL (seconds) for /api/commands/discover
COMMAND_DISCOVERY_CACHE_TTL_SECONDS=300
# Redact common secrets/PII from container log snapshots (GET /api/containers/{id})
LOG_SNAPSHOT_REDACTION_ENABLED=true
# Optional extra regex patterns separated by "||" (replaced by [REDACTED])
LOG_SNAPSHOT_REDACTION_EXTRA_PATTERNS=
# Audit logs retention (days) used by purge endpoint/CLI
AUDIT_RETENTION_DAYS=90
# Enable periodic automatic purge service
AUDIT_RETENTION_AUTO_ENABLED=true
# Automatic purge interval in seconds
AUDIT_RETENTION_POLL_SECONDS=86400

# Frontend: vide = même origine (proxy Next.js, évite 401 cookies)
# Pour accès direct: http://localhost:8000 ou http://<IP>:8000
NEXT_PUBLIC_API_URL=

# Notifications (alertes)
# ntfy: push notifications (downtime, seuils CPU/RAM)
# NTFY_BASE_URL=https://ntfy.example.com
# NTFY_TOPIC=my-dashboard-alerts
NTFY_BASE_URL=
NTFY_TOPIC=
# Resend: emails sur alertes (style Uptime Robot), domaine vérifié requis
# RESEND_API_KEY=re_xxx
# ALERT_EMAIL_FROM=Dashboard <alerts@votre-domaine.com>
# ALERT_EMAIL_TO=admin@example.com,ops@example.com
RESEND_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# act (GitHub Actions local run) — optional
ACT_ENABLED=false
# Path inside container to repo with .github/workflows (default: /workspace, mounted via docker compose)
ACT_WORKFLOWS_PATH=/workspace

# E2E Playwright authenticated flow (optional)
E2E_USERNAME=
E2E_PASSWORD=
